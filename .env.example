# Supabase (server + browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# AI proposal generation + document extraction (Groq vision)
# Get key at console.groq.com
LOVABLE_API_KEY=
GROQ_API_KEY=

# GoHighLevel voice/SMS/email integration
GHL_API_TOKEN=
GHL_LOCATION_ID=
GHL_FROM_NUMBER=+13109874997
GHL_EMAIL_FROM=noreply@suddenimpactagency.io
VITE_GHL_AGENT_NUMBER=+13109874997
# ID of the GHL workflow "Jessica - FollowUp Call" (contains Voice AI action + tags + wait)
GHL_JESSICA_FOLLOWUP_WORKFLOW_ID=

# Contractor self-onboarding notifications (sent when a new application is submitted)
NGS_NOTIFY_EMAIL=
NGS_NOTIFY_PHONE=

# Contractor Recruitment API
# Bearer token required by POST /api/public/contractor-recruit
CONTRACTOR_RECRUIT_API_KEY=

# Google Places API — used by the "Find Contractors" dashboard to search for
# contractors by NGS service niche + state/city via Google Places Text Search.
# Enable "Places API (New)" in Google Cloud Console → APIs & Services.
GOOGLE_PLACES_API_KEY=

# Retell AI — for web-based voice calls (Jessica web call widget)
# Get API key from https://retell.ai/dashboard
RETELL_API_KEY=

# GHL workflow to trigger when a new recruit is created (hiring-agent / Jessica outreach)
# Set this to the workflow ID in GoHighLevel that handles proactive contractor outreach
GHL_HIRING_AGENT_WORKFLOW_ID=

# GHL voice pre-qualification workflow (Jessica calls recruited contractors)
# Configure GHL to POST to: https://jobbidder.io/api/public/webhook/ghl-voice-prequal
# when a call ends — we record the result and auto-send an upload-link SMS
GHL_VOICE_PREQUAL_WORKFLOW_ID=

# Comma-separated 2-letter state codes where NGS operates (default: CA,NV,AZ,TX)
# Only contractors licensed in these states will pass the eligibility check
NGS_OPERATING_STATES=CA,NV,AZ,TX

# Public site URL used in invite links (e.g. https://jobbidder.io)
VITE_SITE_URL=

# Comma-separated admin emails — only these accounts can access the dashboard
# Both vars must match: ADMIN_EMAILS for server functions, VITE_ADMIN_EMAILS for client routing
ADMIN_EMAILS=don@suddenimpactagency.io
VITE_ADMIN_EMAILS=don@suddenimpactagency.io
